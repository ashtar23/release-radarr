# Runtime
# Allowed values: development, staging, production, test
PORT=3001
HOST=0.0.0.0
APP_ENV=development

# Phase 1 primary data path
DATABASE_URL=

# Transitional migration-only envs. Keep unset for the current direct-DB home
# route. These remain available for later endpoints that may still verify auth
# against Supabase or temporarily rely on Supabase-backed access during the
# migration.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Transitional provider integration. Not used by the current home route.
RAWG_API_KEY=
