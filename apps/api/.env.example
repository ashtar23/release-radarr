# Runtime
# Allowed values: development, staging, production, test
PORT=3001
HOST=0.0.0.0
APP_ENV=development

# Browser origins allowed to call this API directly.
# Development defaults to http://localhost:5173 when left unset.
# Non-development environments must set this explicitly.
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ALLOWED_ORIGINS=

# Phase 1 primary data path
DATABASE_URL=

# Transitional migration-only envs. Keep unset for the current direct-DB home
# route. These remain available for later endpoints that may still verify auth
# against Supabase or temporarily rely on Supabase-backed access during the
# migration.
# Authenticated migrated routes such as notifications/unread-count require the
# Supabase auth verifier envs below.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Transitional provider integration. Not used by the current home route.
RAWG_API_KEY=
