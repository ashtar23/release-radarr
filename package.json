{
  "name": "release-radarr",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "verify:pre-push": "pnpm --filter @repo/types check-types && pnpm --filter @repo/api-client check-types && pnpm --filter mobile check-types && pnpm lint --filter mobile && deno check --config supabase/functions/api/deno.json --lock=supabase/functions/api/deno.lock supabase/functions/api/index.ts",
    "prepare": "husky",
    "test:backend-contracts": "node supabase/tests/contracts.mjs",
    "release:mobile:version": "node scripts/bump-mobile-version.mjs",
    "supabase:staging:functions": "node scripts/supabase-deploy.mjs staging functions",
    "supabase:staging:db": "node scripts/supabase-deploy.mjs staging db",
    "supabase:staging:all": "node scripts/supabase-deploy.mjs staging all",
    "supabase:prod:functions": "node scripts/supabase-deploy.mjs prod functions",
    "supabase:prod:db": "node scripts/supabase-deploy.mjs prod db",
    "supabase:prod:all": "node scripts/supabase-deploy.mjs prod all",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile start",
    "ios": "pnpm --filter mobile ios",
    "android": "pnpm --filter mobile android",
    "web:mobile": "pnpm --filter mobile web"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.8.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "version": "1.0.0",
  "dependencies": {
    "expo": "~55.0.5",
    "react": "19.2.0",
    "react-native": "0.83.2"
  }
}
